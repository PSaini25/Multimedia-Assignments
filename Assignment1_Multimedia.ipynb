import cv2
import numpy as np

# -------------------------------
# a. Read, display, and write an image
# -------------------------------
image = cv2.imread('input.jpg')   # Replace with your image path

cv2.imshow('Original Image', image)
cv2.imwrite('output.jpg', image)

cv2.waitKey(0)
cv2.destroyAllWindows()


# -------------------------------
# b. Convert image into different formats
# -------------------------------
cv2.imwrite('image.png', image)
cv2.imwrite('image.tiff', image)


# -------------------------------
# c. Image resizing
# -------------------------------
resized = cv2.resize(image, (300, 300))
cv2.imshow('Resized Image', resized)

cv2.waitKey(0)
cv2.destroyAllWindows()


# -------------------------------
# d. Convert colored image to grayscale
# -------------------------------
gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
cv2.imshow('Grayscale Image', gray)

cv2.waitKey(0)
cv2.destroyAllWindows()


# -------------------------------
# e. Transformations
# -------------------------------

rows, cols = image.shape[:2]

# Scaling
scaled = cv2.resize(image, None, fx=1.5, fy=1.5)

# Rotation
matrix_rotate = cv2.getRotationMatrix2D((cols/2, rows/2), 45, 1)
rotated = cv2.warpAffine(image, matrix_rotate, (cols, rows))

# Shifting (Translation)
matrix_shift = np.float32([[1, 0, 50], [0, 1, 50]])
shifted = cv2.warpAffine(image, matrix_shift, (cols, rows))

# Shearing
matrix_shear = np.float32([[1, 0.5, 0], [0.5, 1, 0]])
sheared = cv2.warpAffine(image, matrix_shear, (cols, rows))

# Display all
cv2.imshow('Scaled', scaled)
cv2.imshow('Rotated', rotated)
cv2.imshow('Shifted', shifted)
cv2.imshow('Sheared', sheared)

cv2.waitKey(0)
cv2.destroyAllWindows()


# -------------------------------
# f. Read and display a video
# -------------------------------
video = cv2.VideoCapture('video.mp4')  # Replace with your video path

while True:
    ret, frame = video.read()
    if not ret:
        break

    cv2.imshow('Video', frame)

    if cv2.waitKey(25) & 0xFF == ord('q'):
        break

video.release()
cv2.destroyAllWindows()


# -------------------------------
# g. Extract frames from video
# -------------------------------
video = cv2.VideoCapture('video.mp4')
count = 0

while True:
    ret, frame = video.read()
    if not ret:
        break

    cv2.imwrite(f'frame_{count}.jpg', frame)
    count += 1

video.release()
print("Frames extracted successfully!")
