# MAIN MENU
# =========================================
if __name__ == "__main__":
    while True:
        print("\n--- Experiment 5 Menu ---")
        print("1. Plot Histograms")
        print("2. Histogram Equalization")
        print("3. Histogram Matching")
        print("4. Histogram Stretching")
        print("0. Exit")

        choice = input("Enter your choice: ")

        if choice == '1':
            histogram_plot()
        elif choice == '2':
            histogram_equalization()
        elif choice == '3':
            histogram_matching()
        elif choice == '4':
            histogram_stretching()
